generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id                   String    @id @default(cuid())
  mint                 String    @unique
  name                 String
  ticker               String
  description          String
  imageUrl             String?
  creatorWallet        String    // agent wallet public key (= pump.fun creator)
  agentEncKey          String?   // AES-256-GCM encrypted agent private key
  creatorName          String    @default("anonymous")
  createdAt            DateTime  @default(now())
  twitter              String?
  telegram             String?
  website              String?
  buybackRate          Int
  buybackTimeframe     String
  buybackLocked        Boolean   @default(true)
  buybackLockedAt      DateTime  @default(now())
  hasLP                Boolean   @default(false)
  lpFeeShare           Int       @default(0)
  marketCap            Float     @default(0)
  price                Float     @default(0)
  priceChange24h       Float     @default(0)
  volume24h            Float     @default(0)
  revenue              Float     @default(0)
  buybacksCompleted    Float     @default(0)
  buybacksPending      Float     @default(0)
  totalBurned          Float     @default(0)
  replies              Int       @default(0)
  bondingCurveProgress Float     @default(0)
  agentActive          Boolean   @default(false)
  lastBuybackAt        DateTime?

  buybackEvents BuybackEvent[]

  @@index([createdAt])
  @@index([agentActive])
}

model BuybackEvent {
  id          String   @id @default(cuid())
  tokenMint   String
  amount      Float
  txSignature String   @unique
  executedAt  DateTime @default(now())

  token Token @relation(fields: [tokenMint], references: [mint])

  @@index([tokenMint, executedAt])
}

// Temporarily-held agent wallets awaiting token launch
model PendingAgent {
  id        String   @id @default(cuid())
  address   String   @unique
  encKey    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([address])
  @@index([expiresAt])
}
